---
import '../../styles/pages/nosotros.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { siteSettings, staticPages } from '../../data/snapshot';

const page = staticPages.find((item) => item.slug === 'libro-de-reclamaciones');
const currentYear = new Date().getFullYear();
const previewCode = `ML-${currentYear}-${String(Math.floor(Math.random() * 100000)).padStart(5, '0')}`;
---

<BaseLayout
  seo={{
    title: page?.seo?.title || `Libro de Reclamaciones | ${siteSettings.siteName}`,
    description: page?.seo?.description || page?.content || 'Libro de reclamaciones digital.',
    canonicalPath: '/libro-de-reclamaciones/',
  }}
>
  <Header />

  <main id="contenido" class="about-page">
    <section class="about-hero">
      <div class="container about-hero__inner">
        <nav class="about-hero__breadcrumb" aria-label="Breadcrumb">
          <a href="/">Inicio</a>
          <span aria-hidden="true">/</span>
          <strong>Libro de Reclamaciones</strong>
        </nav>
        <h1>Libro de Reclamaciones</h1>
      </div>
    </section>

    <section class="claim-section">
      <div class="container claim-section__inner">
        <p class="claim-intro">
          Conforme a lo establecido en el Código de Protección y Defensa del Consumidor, esta institución cuenta con un
          Libro de Reclamaciones a su disposición. Le daremos respuesta a su reclamo en un plazo máximo de quince
          (15) días hábiles, como lo establece la ley.
        </p>

        <form class="claim-form" id="claim-form">
          <div class="claim-form__row claim-form__row--2">
            <fieldset class="claim-fieldset">
              <legend>Tipo de solicitud</legend>
              <label><input type="radio" name="claimType" value="reclamo" checked /> Reclamo</label>
              <label><input type="radio" name="claimType" value="queja" /> Queja</label>
            </fieldset>

            <fieldset class="claim-fieldset">
              <legend>Fecha</legend>
              <p class="claim-static" id="claim-date"></p>
              <p class="claim-code" id="claim-code">{previewCode}</p>
            </fieldset>
          </div>

          <h2 class="claim-section-title">Datos personales</h2>

          <div class="claim-form__row claim-form__row--3">
            <label>
              <span class="claim-required">Correo electrónico</span>
              <input name="email" type="email" autocomplete="email" required />
            </label>
            <label class="claim-span-2">
              <span class="claim-required">Nombres y Apellidos</span>
              <input name="consumerName" type="text" autocomplete="name" required />
            </label>
          </div>

          <div class="claim-form__row claim-form__row--3">
            <label>
              <span class="claim-required">Tipo de documento</span>
              <select name="documentType" required>
                <option value="dni">DNI</option>
                <option value="ce">Carné de extranjería</option>
                <option value="pasaporte">Pasaporte</option>
                <option value="otro">Otro</option>
              </select>
            </label>
            <label>
              <span class="claim-required">Número de documento</span>
              <input name="documentNumber" type="text" inputmode="numeric" data-numeric-only required />
            </label>
            <label>
              <span class="claim-required">Teléfono o celular</span>
              <input name="phone" type="tel" autocomplete="tel" data-phone-input required />
            </label>
          </div>

          <div class="claim-form__row claim-form__row--3">
            <label>
              <span class="claim-required">Departamento</span>
              <input name="department" type="text" required />
            </label>
            <label>
              <span class="claim-required">Provincia</span>
              <input name="province" type="text" required />
            </label>
            <label>
              <span class="claim-required">Distrito</span>
              <input name="district" type="text" required />
            </label>
          </div>

          <div class="claim-form__row claim-form__row--1">
            <label>
              <span class="claim-required">Dirección</span>
              <input name="address" type="text" required />
            </label>
          </div>

          <h2 class="claim-section-title">Detalles del reclamo</h2>

          <div class="claim-form__row claim-form__row--3">
            <label>
              <span class="claim-required">Bien a reclamar</span>
              <input name="productService" type="text" placeholder="Ejemplo: Hidrolavadora Karcher K2" required />
            </label>
            <label>
              <span>Número del pedido</span>
              <input name="orderNumber" type="text" inputmode="numeric" data-numeric-only />
            </label>
            <label>
              <span>Monto reclamado</span>
              <input name="amount" type="text" inputmode="numeric" data-numeric-only />
            </label>
          </div>

          <div class="claim-form__row claim-form__row--1">
            <label>
              <span class="claim-required">Descripción del bien contratado</span>
              <textarea name="contractedGoodDescription" rows="4" required></textarea>
            </label>
          </div>

          <div class="claim-form__row claim-form__row--1">
            <label>
              <span class="claim-required">Detalle de la reclamación o queja</span>
              <textarea name="detail" rows="5" required></textarea>
            </label>
          </div>

          <div class="claim-form__row claim-form__row--1">
            <label>
              <span class="claim-required">Pedido del consumidor</span>
              <textarea name="request" rows="4" required></textarea>
            </label>
          </div>

          <div class="claim-form__row claim-form__row--1">
            <label>
              <span>Canal de compra</span>
              <select name="purchaseChannel">
                <option value="">Seleccionar</option>
                <option value="Tienda física">Tienda física</option>
                <option value="Página web">Página web</option>
              </select>
            </label>
          </div>

          <label class="claim-check">
            <input type="checkbox" name="isMinor" id="is-minor" />
            <span class="claim-check__box" aria-hidden="true"></span>
            <span class="claim-check__text">El consumidor es menor de edad</span>
          </label>

          <div class="claim-minor" id="minor-fields" hidden>
            <div class="claim-form__row claim-form__row--2">
              <label>
                <span class="claim-required">Nombre del padre, madre o representante</span>
                <input name="guardianName" type="text" />
              </label>
              <label>
                <span class="claim-required">Documento del representante</span>
                <input name="guardianDocument" type="text" inputmode="numeric" data-numeric-only />
              </label>
            </div>
            <div class="claim-form__row claim-form__row--2">
              <label>
                <span class="claim-required">Teléfono del representante</span>
                <input name="guardianPhone" type="tel" data-phone-input />
              </label>
              <label>
                <span class="claim-required">Correo del representante</span>
                <input name="guardianEmail" type="email" />
              </label>
            </div>
          </div>

          <label class="claim-check">
            <input type="checkbox" name="accept" required />
            <span class="claim-check__box" aria-hidden="true"></span>
            <span class="claim-check__text">
              Acepto los <a href="/terminos-y-condiciones/">Términos y Condiciones</a> y la
              <a href="/politicas-de-privacidad/">Política de Privacidad</a>. Declaro que la información consignada
              es veraz y autorizo el tratamiento de mis datos para la atención del reclamo.
            </span>
          </label>

          <button class="btn btn-primary claim-submit" type="submit">Enviar reclamo</button>
          <p class="claim-feedback" id="claim-feedback" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>

<script>
  const form = document.getElementById('claim-form');
  const feedback = document.getElementById('claim-feedback');
  const minorToggle = document.getElementById('is-minor');
  const minorFields = document.getElementById('minor-fields');
  const dateTarget = document.getElementById('claim-date');
  const codeTarget = document.getElementById('claim-code');

  if (dateTarget instanceof HTMLElement) {
    const now = new Date();
    const parts = new Intl.DateTimeFormat('es-PE', {
      timeZone: 'America/Lima',
      day: '2-digit',
      month: '2-digit',
      year: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
    }).formatToParts(now);
    const get = (type: string) => parts.find((part) => part.type === type)?.value || '';
    dateTarget.textContent = `${get('day')}/${get('month')}/${get('year')} - ${get('hour')}:${get('minute')}`;
  }

  if (minorToggle instanceof HTMLInputElement && minorFields instanceof HTMLElement) {
    const syncMinorFields = () => {
      minorFields.hidden = !minorToggle.checked;
      minorFields.querySelectorAll('input').forEach((input) => {
        if (input instanceof HTMLInputElement) {
          input.required = minorToggle.checked;
        }
      });
    };

    minorToggle.addEventListener('change', syncMinorFields);
    syncMinorFields();
  }

  document.querySelectorAll('[data-numeric-only]').forEach((input) => {
    if (input instanceof HTMLInputElement) {
      input.addEventListener('input', () => {
        input.value = input.value.replace(/\D+/g, '');
      });
    }
  });

  document.querySelectorAll('[data-phone-input]').forEach((input) => {
    if (input instanceof HTMLInputElement) {
      input.addEventListener('input', () => {
        const normalized = input.value.replace(/[^\d+]/g, '').replace(/(?!^)\+/g, '');
        input.value = normalized.startsWith('+') ? `+${normalized.slice(1).replace(/\+/g, '')}` : normalized;
      });
    }
  });

  if (form instanceof HTMLFormElement && feedback instanceof HTMLElement) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      feedback.textContent = 'Enviando reclamo...';
      const submitButton = form.querySelector('button[type="submit"]');
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
      }

      try {
        const data = new FormData(form);
        const payload = Object.fromEntries(data.entries()) as Record<string, FormDataEntryValue | boolean>;
        payload.isMinor = data.get('isMinor') === 'on';

        const response = await fetch('/api/libro-de-reclamaciones/', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify(payload),
        });

        const contentType = response.headers.get('content-type') || '';
        const result = contentType.includes('application/json') ? await response.json() : {error: await response.text()};

        if (!response.ok) {
          throw new Error(result.error || 'No se pudo enviar el reclamo.');
        }

        if (codeTarget instanceof HTMLElement) {
          codeTarget.textContent = result.id;
        }

        feedback.innerHTML = `Reclamo enviado. Código: <strong>${result.id}</strong>. <a href="/libro-de-reclamaciones/comprobante/${result.id}/" target="_blank" rel="noreferrer">Descargar constancia</a>`;
        form.reset();
        if (minorFields instanceof HTMLElement) {
          minorFields.hidden = true;
        }
      } catch (error) {
        feedback.textContent = error instanceof Error ? error.message : 'No se pudo enviar el reclamo.';
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
        }
      }
    });
  }
</script>

<style>
  .claim-section {
    padding: clamp(28px, 5vw, 56px) 0 clamp(42px, 6vw, 72px);
  }

  .claim-section__inner {
    padding-inline: clamp(20px, 6vw, 84px);
  }

  .claim-intro {
    max-width: 980px;
    margin: 0 auto 24px;
    font-size: clamp(1rem, 1.05vw, 1.05rem);
    line-height: 1.8;
    color: var(--text);
  }

  .claim-form {
    max-width: 980px;
    margin: 0 auto;
    display: grid;
    gap: 18px;
    font-size: clamp(1rem, 1.05vw, 1.05rem);
  }

  .claim-form :where(input, select, textarea) {
    font: inherit;
    color: var(--text);
    width: 100%;
    border: var(--border-width) var(--border-style) var(--line);
    background: var(--surface);
    padding: 11px 12px;
  }

  .claim-form :where(label) {
    display: grid;
    gap: 6px;
  }

  .claim-form__row {
    display: grid;
    gap: 14px;
  }

  .claim-form__row--1 {
    grid-template-columns: 1fr;
  }

  .claim-form__row--2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .claim-form__row--3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .claim-span-2 {
    grid-column: span 2;
  }

  .claim-fieldset {
    margin: 0;
    border: var(--border-width) var(--border-style) var(--line);
    padding: 14px;
    display: grid;
    gap: 12px;
  }

  .claim-fieldset legend,
  .claim-form label > span {
    font-size: inherit;
    font-weight: 600;
    color: var(--text);
  }

  .claim-fieldset label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 400;
  }

  .claim-fieldset input {
    width: auto;
  }

  .claim-required::before {
    content: '*';
    color: #d11a2a;
    margin-right: 4px;
  }

  .claim-static,
  .claim-code {
    margin: 0;
    font: inherit;
    font-weight: 600;
    white-space: nowrap;
  }

  .claim-section-title {
    margin: 8px 0 0;
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
  }

  .claim-check {
    display: grid;
    grid-template-columns: 18px minmax(0, 1fr);
    gap: 10px;
    align-items: start;
    line-height: 1.55;
    cursor: pointer;
  }

  .claim-check input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .claim-check__box {
    width: 18px;
    height: 18px;
    margin-top: 3px;
    border: 1.5px solid color-mix(in srgb, var(--line) 75%, var(--text));
    border-radius: 4px;
    background: var(--surface);
    display: inline-block;
    position: relative;
    transition: border-color 0.18s ease, background-color 0.18s ease, box-shadow 0.18s ease;
  }

  .claim-check:hover .claim-check__box {
    border-color: color-mix(in srgb, var(--brand) 35%, var(--line));
  }

  .claim-check input:focus-visible + .claim-check__box {
    outline: 2px solid color-mix(in srgb, var(--brand) 48%, white);
    outline-offset: 2px;
  }

  .claim-check input:checked + .claim-check__box {
    background: var(--brand);
    border-color: var(--brand);
    box-shadow: inset 0 0 0 2px color-mix(in srgb, white 90%, transparent);
  }

  .claim-check input:checked + .claim-check__box::after {
    content: '';
    position: absolute;
    left: 4px;
    top: 1px;
    width: 6px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .claim-check__text {
    font-weight: 600;
  }

  .claim-check__text a,
  .claim-feedback a {
    color: var(--brand);
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .claim-minor {
    display: grid;
    gap: 14px;
  }

  .claim-submit {
    width: 100%;
    min-height: 48px;
  }

  .claim-feedback {
    min-height: 1.5em;
    margin: 0;
  }

  @media (max-width: 900px) {
    .claim-form__row--3,
    .claim-form__row--2 {
      grid-template-columns: 1fr;
    }

    .claim-span-2 {
      grid-column: auto;
    }
  }

  @media (max-width: 760px) {
    .claim-section__inner {
      padding-inline: 0;
    }
  }
</style>
