---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { siteSettings, staticPages } from '../../data/snapshot';

const page = staticPages.find((item) => item.slug === 'about-us');
---

<BaseLayout
  seo={{
    title: page?.seo?.title || `Sobre Nosotros | ${siteSettings.siteName}`,
    description: page?.seo?.description || page?.content || 'Información corporativa de Maquinarias Luedma.',
    canonicalPath: '/about-us/',
  }}
>
  <Header />

  <main id="contenido" class="page-shell">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Sobre nosotros', href: '/about-us/' }]} />
      <section class="card page-panel">
        <h1>Sobre nosotros</h1>
        <p>{page?.content}</p>
        <p>
          Esta versión conserva la estructura visual del storefront original y prepara el camino
          para integrar checkout y carrito con backend Node.js.
        </p>
      </section>
    </div>
  </main>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>

