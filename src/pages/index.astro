---
import '../styles/pages/home.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { brands } from '../data/snapshot';
import { hasSanityConfig, sanityFetch } from '../lib/sanity.client';

type ShowcaseItem = {
  slug?: string;
  brand: string;
  name: string;
  sku?: string;
  badge?: string;
  image?: string;
  path?: string;
};
const buildShopBrandFilterPath = (slug: string) => `/tienda/m/${encodeURIComponent(slug)}/`;
const toCardThumb = (src?: string) => {
  if (!src) return src;
  return src.includes('cdn.sanity.io') ? `${src}?w=400&h=400&fit=crop&auto=format` : src;
};
type CmsHomeData = {
  heroSlides?: Array<{
    alt?: string;
    imageDesktop?: { asset?: { url?: string } };
    imageMobile?: { asset?: { url?: string } };
    link?: { href?: string };
  }>;
  featuredProductsByBrand?: Array<{
    brand?: { name?: string; slug?: string };
    products?: Array<{
      name?: string;
      slug?: string;
      sku?: string;
      isNew?: boolean;
      images?: Array<{ asset?: { url?: string } }>;
    }>;
  }>;
  featuredProductsCarousel?: Array<{
    name?: string;
    slug?: string;
    sku?: string;
    isNew?: boolean;
    brand?: { name?: string };
    images?: Array<{ asset?: { url?: string } }>;
  }>;
  promoBanners?: Array<{
    alt?: string;
    image?: { asset?: { url?: string } };
    link?: { href?: string };
  }>;
  trustStrip?: Array<{ icon?: string; title?: string; text?: string }>;
};

let homeCms: CmsHomeData | null = null;

if (hasSanityConfig) {
  try {
    homeCms = await sanityFetch<CmsHomeData>(`*[_type == "homePage"][0]{
      heroSlides[0...5]{
        alt,
        imageDesktop{asset->{url}},
        imageMobile{asset->{url}},
        link{href}
      },
      featuredProductsByBrand[0...5]{
        brand->{name, "slug": slug.current},
        products[0...8]->{
          name,
          "slug": slug.current,
          sku,
          isNew,
          images[]{asset->{url}}
        }
      },
      featuredProductsCarousel[0...12]->{
        name,
        "slug": slug.current,
        sku,
        isNew,
        brand->{name},
        images[]{asset->{url}}
      },
      promoBanners[0...2]{
        alt,
        image{asset->{url}},
        link{href}
      }
    }`);
  } catch {
    homeCms = null;
  }
}
const isExternalHref = (href?: string) => Boolean(href && /^(https?:)?\/\//.test(href));
const cmsShowcaseEntries =
  homeCms?.featuredProductsByBrand?.filter((entry): entry is NonNullable<typeof entry> => Boolean(entry)).map((entry, entryIndex) => {
    const brandLabel = entry.brand?.name?.trim();
    const brandSlug = entry.brand?.slug?.trim();
    if (!brandLabel || !brandSlug || !entry.products || entry.products.length === 0) {
      return null;
    }

    const key = `${brandSlug}-${entryIndex}`;
    const items = entry.products
      .filter((product): product is NonNullable<typeof product> => Boolean(product))
      .slice(0, 8)
      .map((product) => ({
        slug: product.slug,
        brand: brandLabel,
        name: product.name || 'Producto',
        sku: product.sku || undefined,
        badge: product.isNew ? 'NUEVO' : undefined,
        image: toCardThumb(product.images?.[0]?.asset?.url),
        path: product.slug ? `/product/${product.slug}/` : '/tienda/',
      }));

    return { key, label: brandLabel, items };
  }).filter((entry): entry is { key: string; label: string; items: ShowcaseItem[] } => Boolean(entry)) || [];

const SHOWCASE_BRAND_TABS =
  cmsShowcaseEntries.length > 0
    ? cmsShowcaseEntries.map(({ key, label }) => ({ key, label }))
    : [{ key: 'fallback', label: 'Destacados' }];
const effectiveShowcaseIndex =
  cmsShowcaseEntries.length > 0
    ? cmsShowcaseEntries.reduce<Record<string, ShowcaseItem[]>>((acc, entry) => {
        acc[entry.key] = entry.items;
        return acc;
      }, {})
    : {
        fallback: [],
      };
const defaultKey = SHOWCASE_BRAND_TABS[0].key;
const defaultItems = effectiveShowcaseIndex[defaultKey] || [];

const marqueeBrandImagesFromCms = brands
  .filter((brand) => Boolean(brand.logo))
  .slice(0, 12)
  .map((brand) => ({
    name: brand.name,
    slug: brand.slug,
    logo: brand.logo as string,
    path: buildShopBrandFilterPath(brand.slug),
  }));
const marqueeBrandImages =
  marqueeBrandImagesFromCms.length > 0
    ? marqueeBrandImagesFromCms
    : [
        { name: 'bosch', slug: 'bosch', logo: '/images/brands/bosch.webp', path: buildShopBrandFilterPath('bosch') },
        { name: 'DeWalt', slug: 'dewalt', logo: '/images/brands/dewalt.webp', path: buildShopBrandFilterPath('dewalt') },
        { name: 'hilti', slug: 'hilti', logo: '/images/brands/hilti.webp', path: buildShopBrandFilterPath('hilti') },
        { name: 'irwin', slug: 'irwin', logo: '/images/brands/irwin.webp', path: buildShopBrandFilterPath('irwin') },
        { name: 'karcher', slug: 'karcher', logo: '/images/brands/karcher.webp', path: buildShopBrandFilterPath('karcher') },
        { name: 'makute', slug: 'makute', logo: '/images/brands/makute.webp', path: buildShopBrandFilterPath('makute') },
        { name: 'ronix', slug: 'ronix', logo: '/images/brands/ronix.webp', path: buildShopBrandFilterPath('ronix') },
        { name: 'sagola', slug: 'sagola', logo: '/images/brands/sagola.webp', path: buildShopBrandFilterPath('sagola') },
        { name: 'stanley', slug: 'stanley', logo: '/images/brands/stanley.webp', path: buildShopBrandFilterPath('stanley') },
        { name: 'total', slug: 'total', logo: '/images/brands/total.webp', path: buildShopBrandFilterPath('total') },
        { name: 'truper', slug: 'truper', logo: '/images/brands/truper.webp', path: buildShopBrandFilterPath('truper') },
        { name: 'wagner', slug: 'wagner', logo: '/images/brands/wagner.webp', path: buildShopBrandFilterPath('wagner') },
      ];
const uniqueMarqueeBrandImages = Array.from(new Map(marqueeBrandImages.map((brand) => [brand.slug, brand])).values());
const marqueeBrands = uniqueMarqueeBrandImages.length > 1
  ? [...uniqueMarqueeBrandImages, ...uniqueMarqueeBrandImages]
  : uniqueMarqueeBrandImages;
const heroSlides =
  homeCms?.heroSlides && homeCms.heroSlides.length > 0
    ? homeCms.heroSlides
        .filter((item): item is NonNullable<typeof item> => Boolean(item))
        .slice(0, 5)
        .map((item, index) => ({
          desktop: item.imageDesktop?.asset?.url || '/images/banners/banner-principal-1.webp',
          mobile: item.imageMobile?.asset?.url || '/images/banners/movil/banner-principal-movil.webp',
          alt: item.alt || `Banner principal ${index + 1}`,
          href: item.link?.href?.trim() || undefined,
        }))
    : [
        {
          desktop: '/images/banners/banner-principal-1.webp',
          mobile: '/images/banners/movil/banner-principal-movil.webp',
          alt: 'Banner principal 1',
          href: undefined,
        },
        {
          desktop: '/images/banners/banner-principal-1.webp',
          mobile: '/images/banners/movil/banner-principal-movil.webp',
          alt: 'Banner principal 2',
          href: undefined,
        },
        {
          desktop: '/images/banners/banner-principal-1.webp',
          mobile: '/images/banners/movil/banner-principal-movil.webp',
          alt: 'Banner principal 3',
          href: undefined,
        },
      ];
const offersBanners =
  homeCms?.promoBanners && homeCms.promoBanners.length > 0
    ? homeCms.promoBanners
        .filter((item): item is NonNullable<typeof item> => Boolean(item))
        .slice(0, 2)
        .map((item, index) => ({
          image: item.image?.asset?.url || `/images/banners/banner-tool-${index + 1}.webp`,
          alt: item.alt || `Banner promocional ${index + 1}`,
          href: item.link?.href?.trim() || undefined,
        }))
    : [
        {
          image: '/images/banners/banner-tool-1.webp',
          alt: 'Banner herramienta destacado',
          href: undefined,
        },
        {
          image: '/images/banners/banner-tool-2.webp',
          alt: 'Banner herramienta promocional',
          href: undefined,
        },
      ];
const showcasePreviewImages = [
  '/images/products/p3.jpg',
  '/images/products/p1.png',
  '/images/products/p6.jpg',
  '/images/products/p2.jpg',
  '/images/products/p8.jpg',
  '/images/products/p5.jpg',
  '/images/products/p4.jpg',
  '/images/products/p7.jpg',
];
const featuredProductsFromCms =
  homeCms?.featuredProductsCarousel
    ?.filter((product): product is NonNullable<typeof product> => Boolean(product))
    .map((product) => ({
      slug: product.slug,
      brand: product.brand?.name || 'Marca',
      name: product.name || 'Producto',
      sku: product.sku || undefined,
      badge: product.isNew ? 'NUEVO' : undefined,
      image: toCardThumb(product.images?.[0]?.asset?.url),
      path: product.slug ? `/product/${product.slug}/` : '/tienda/',
    })) || [];
const featuredProducts: ShowcaseItem[] =
  featuredProductsFromCms.length > 0 ? featuredProductsFromCms.slice(0, 12) : Object.values(effectiveShowcaseIndex).flat().slice(0, 12);
const featuredPages = Array.from({ length: Math.ceil(featuredProducts.length / 4) }, (_, pageIndex) =>
  featuredProducts.slice(pageIndex * 4, pageIndex * 4 + 4)
);
---

<BaseLayout>
  <Header />

  <main id="contenido">
    <section class="hero-carousel" data-island="hero-carousel" aria-label="Carrusel principal">
      <div class="hero-carousel__viewport">
        <div class="hero-carousel__track" data-hero-track>
          {heroSlides.map((slide, index) => (
            <article class="hero-carousel__slide">
              {slide.href ? (
                <a
                  href={slide.href}
                  aria-label={slide.alt}
                  target={isExternalHref(slide.href) ? '_blank' : undefined}
                  rel={isExternalHref(slide.href) ? 'noreferrer' : undefined}
                >
                  <picture>
                    <source media="(max-width: 760px)" srcset={slide.mobile} />
                    <img
                      src={slide.desktop}
                      alt={slide.alt}
                      width="1920"
                      height="640"
                      loading={index === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  </picture>
                </a>
              ) : (
                <picture>
                  <source media="(max-width: 760px)" srcset={slide.mobile} />
                  <img
                    src={slide.desktop}
                    alt={slide.alt}
                    width="1920"
                    height="640"
                    loading={index === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </picture>
              )}
            </article>
          ))}
        </div>
      </div>

      <button class="hero-carousel__arrow hero-carousel__arrow--prev" type="button" data-hero-prev aria-label="Diapositiva anterior"></button>
      <button class="hero-carousel__arrow hero-carousel__arrow--next" type="button" data-hero-next aria-label="Diapositiva siguiente"></button>

      <div class="hero-carousel__dots" data-hero-dots>
        {heroSlides.map((_, index) => (
          <button
            class={index === 0 ? 'is-active' : undefined}
            type="button"
            data-hero-dot={index}
            aria-label={`Ir al slide ${index + 1}`}
            aria-selected={index === 0 ? 'true' : 'false'}
          ></button>
        ))}
      </div>
    </section>

    <section class="section home-showcase" data-island="home-product-selector">
      <div class="container">
        <h1 class="home-showcase__title">Los mejores equipos en taladros y otras herramientas en Lima con envío rápido</h1>

        <div class="home-showcase__tabs" role="tablist" aria-label="Selector de productos por marca">
          {SHOWCASE_BRAND_TABS.map((tab, index) => (
            <button type="button" role="tab" class:list={{ 'is-active': index === 0 }} aria-selected={index === 0 ? 'true' : 'false'} data-showcase-tab={tab.key}>
              {tab.label}
            </button>
          ))}
        </div>

        <div class="showcase-stage" data-showcase-stage>
          <div class="showcase-grid is-current" data-showcase-grid data-showcase-panel={defaultKey}>
            {defaultItems.map((item) => (
              <article class="showcase-card">
                <a href={item.path || '/tienda/'} class="showcase-card__image-link" aria-label={`Ver producto ${item.name}`}>
                  <img
                    src={item.image || showcasePreviewImages[Math.floor(Math.random() * showcasePreviewImages.length)]}
                    alt={`Imagen de ${item.name}`}
                    loading="lazy"
                  />
                </a>

                <div class="showcase-card__meta">
                  <p class="showcase-card__brand">{item.brand}</p>
                  {item.badge && <span class="showcase-card__badge">{item.badge}</span>}
                </div>

                <h3 class="showcase-card__name">{item.name}</h3>

                <div class="showcase-card__footer">
                  <p class="showcase-card__sku">SKU: {item.sku || 'No especificado'}</p>
                  <a class="btn btn-primary showcase-card__cta" href={item.path || '/tienda/'}>Ver detalles</a>
                </div>
              </article>
            ))}
          </div>
        </div>

        <script type="application/json" data-showcase-index set:html={JSON.stringify(effectiveShowcaseIndex)}></script>
      </div>
    </section>

    <section class="section offers-strip" aria-label="Ofertas destacadas">
      <div class="container">
        <div class="offers-strip__row">
          {offersBanners.map((banner) => (
            <article class="offers-strip__item">
              {banner.href ? (
                <a
                  href={banner.href}
                  aria-label={banner.alt}
                  target={isExternalHref(banner.href) ? '_blank' : undefined}
                  rel={isExternalHref(banner.href) ? 'noreferrer' : undefined}
                >
                  <img src={banner.image} alt={banner.alt} loading="lazy" decoding="async" />
                </a>
              ) : (
                <img src={banner.image} alt={banner.alt} loading="lazy" decoding="async" />
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section featured-products" data-island="featured-products-carousel" aria-label="Productos destacados">
      <div class="container">
        <div class="featured-products__head">
          <h2>Productos destacados</h2>
          <a class="btn btn-outline featured-products__cta" href="/tienda/">Ver productos</a>
        </div>

        <div class="featured-products__carousel" data-featured-carousel>
          <button class="featured-products__arrow featured-products__arrow--prev" type="button" data-featured-prev aria-label="Ver productos anteriores">
            <img src="/icons/chevron-left.svg" alt="" aria-hidden="true" />
          </button>

          <div class="featured-products__viewport">
            <div class="featured-products__track" data-featured-track>
              {featuredPages.map((page, pageIndex) => (
                <div class="featured-products__page" data-featured-page={pageIndex}>
                  {page.map((item, itemIndex) => (
                    <article class="showcase-card">
                      <a href={item.path || '/tienda/'} class="showcase-card__image-link" aria-label={`Ver producto ${item.name}`}>
                        <img
                          src={item.image || showcasePreviewImages[(pageIndex * 4 + itemIndex) % showcasePreviewImages.length]}
                          alt={`Imagen de ${item.name}`}
                          loading="lazy"
                        />
                      </a>

                      <div class="showcase-card__meta">
                        <p class="showcase-card__brand">{item.brand}</p>
                        {item.badge && <span class="showcase-card__badge">{item.badge}</span>}
                      </div>

                      <h3 class="showcase-card__name">{item.name}</h3>

                      <div class="showcase-card__footer">
                        <p class="showcase-card__sku">SKU: {item.sku || 'No especificado'}</p>
                        <a class="btn btn-primary showcase-card__cta" href={item.path || '/tienda/'}>Ver detalles</a>
                      </div>
                    </article>
                  ))}
                </div>
              ))}
            </div>
          </div>

          <button class="featured-products__arrow featured-products__arrow--next" type="button" data-featured-next aria-label="Ver más productos">
            <img src="/icons/chevron-right.svg" alt="" aria-hidden="true" />
          </button>
        </div>
      </div>
    </section>

    <section class="section shipping-banner" aria-label="envío destacado">
      <div class="container">
        <picture>
          <source media="(max-width: 760px)" srcset="/images/banners/movil/banner-envio-movil.webp" />
          <img src="/images/banners/banner-envio.webp" alt="Banner de envío" loading="lazy" decoding="async" />
        </picture>
      </div>
    </section>

    <section class="section contact-map" aria-label="Información de tienda y mapa">
      <div class="container contact-map__grid">
        <div class="contact-map__info">
          <h2>Ubícanos</h2>
          <hr class="contact-map__divider" />
          <ul class="contact-map__list">
            <li>
              <span class="contact-map__icon" aria-hidden="true"><img src="/icons/map-pin.svg" alt="" /></span>
              <span>Las Malvinas Jr. Huarochirí 560, Lima, Perú</span>
            </li>
            <li>
              <span class="contact-map__icon" aria-hidden="true"><img src="/icons/brand-whatsapp.svg" alt="" /></span>
              <a href="https://wa.me/51936829528" target="_blank" rel="noreferrer">+51 936 829 528</a>
            </li>
            <li>
              <span class="contact-map__icon" aria-hidden="true"><img src="/icons/mail.svg" alt="" /></span>
              <a href="mailto:maquinariasluedma@gmail.com">maquinariasluedma@gmail.com</a>
            </li>
          </ul>

          <div class="contact-map__extra">
            <h3>Horario de atención</h3>
            <p>Lunes a sábado: 7:00 a. m. - 9:00 p. m.</p>
            <p>Despachos rápidos en Lima Metropolitana.</p>
            <div class="contact-map__socials">
              <a href="#" aria-label="Facebook">
                <img src="/icons/brand-facebook.svg" alt="" />
              </a>
              <a href="#" aria-label="Instagram">
                <img src="/icons/brand-instagram.svg" alt="" />
              </a>
              <a href="#" aria-label="TikTok">
                <img src="/icons/brand-tiktok.svg" alt="" />
              </a>
            </div>
          </div>
        </div>

        <div class="contact-map__embed">
          <iframe
            title="Mapa de Maquinarias Luedma"
            src="https://www.google.com/maps?q=Jr.+Huarochir%C3%AD+560,+Lima,+Per%C3%BA&output=embed"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </section>

    <section class="section" id="marcas">
      <div class="container">
        <h2>Marcas exclusivas en Luedma</h2>
        <div class="brands-marquee" aria-label="Carrusel de marcas">
          <div class="brands-marquee__track">
            {marqueeBrands.map((brand, index) => (
              <a class="brands-marquee__item" href={brand.path} aria-label={`Marca ${brand.name}`}>
                <img src={brand.logo} alt={`Logo ${brand.name}`} loading={index < marqueeBrandImages.length ? 'eager' : 'lazy'} />
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>



