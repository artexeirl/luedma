---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CatalogSection from '../../components/CatalogSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { products } from '../../data/snapshot';

const query = Astro.url.searchParams.get('q') || '';
---

<BaseLayout
  seo={{
    title: query ? `Resultados para: ${query} | Maquinarias Luedma` : 'Buscar productos | Maquinarias Luedma',
    description: query
      ? `Resultados de búsqueda para "${query}" en Maquinarias Luedma`
      : 'Búsqueda local en catálogo migrado a Astro.',
    canonicalPath: '/search/',
    noindex: true,
  }}
>
  <Header />

  <main id="contenido" class="section">
    <div class="container">
      <CatalogSection
        products={products}
        title="Búsqueda y catálogo"
        subtitle="Filtra por texto, marca y orden."
        initialQuery={query}
      />
    </div>
  </main>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
