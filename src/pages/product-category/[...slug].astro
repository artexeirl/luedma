---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CatalogSection from '../../components/CatalogSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { categories, products, siteSettings, getCategoryBySlug } from '../../data/snapshot';
import { categoryParamFromPath } from '../../utils/urls';
import type { Category } from '../../types/content';

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: categoryParamFromPath(category.path) },
    props: { category },
  }));
}

const { category: propCategory } = Astro.props as { category?: Category };
const slugParam = Astro.params.slug as string | undefined;

function resolveCategoryFromSlug(slug: string): Category | undefined {
  const parts = slug.split('/').filter(Boolean);
  const categorySlug = parts[parts.length - 1];
  const category = getCategoryBySlug(categorySlug);
  if (!category) return undefined;
  if (category.parentSlug && parts.length > 1 && parts[parts.length - 2] !== category.parentSlug) return undefined;
  return category;
}

const category = propCategory ?? (slugParam ? resolveCategoryFromSlug(slugParam) : undefined);

if (!category) {
  return Astro.redirect('/404/');
}
---

<BaseLayout
  seo={{
    title: `${category.name} | ${siteSettings.siteName}`,
    description: category.summary || `Catálogo de ${category.name}.`,
    canonicalPath: category.path,
  }}
>
  <Header />

  <main id="contenido" class="section">
    <div class="container">
      <CatalogSection
        products={products}
        initialCategory={category.slug}
      />
    </div>
  </main>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
