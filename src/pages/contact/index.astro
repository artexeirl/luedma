---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { siteSettings, staticPages } from '../../data/snapshot';

const page = staticPages.find((item) => item.slug === 'contact');
---

<BaseLayout
  seo={{
    title: page?.seo?.title || `Contacto | ${siteSettings.siteName}`,
    description: page?.seo?.description || page?.content || 'Contacto comercial de Maquinarias Luedma.',
    canonicalPath: '/contact/',
  }}
>
  <Header />

  <main id="contenido" class="page-shell">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Contacto', href: '/contact/' }]} />
      <section class="card page-panel">
        <h1>Contacto</h1>
        <p>{page?.content}</p>
        <p><strong>Telķfono:</strong> {siteSettings.phone}</p>
        <p><strong>WhatsApp:</strong> +{siteSettings.whatsappNumber}</p>
        <p><strong>Ubicaci¾n:</strong> {siteSettings.location}</p>
        <div class="hero-copy__actions">
          <a class="btn btn-primary" data-island="whatsapp-cta" data-whatsapp-number={siteSettings.whatsappNumber} data-whatsapp-message={siteSettings.whatsappDefaultMessage} target="_blank" rel="noreferrer">Abrir WhatsApp</a>
          <a class="btn btn-outline" href={siteSettings.social.instagram} target="_blank" rel="noreferrer">Instagram</a>
          <a class="btn btn-outline" href={siteSettings.social.facebook} target="_blank" rel="noreferrer">Facebook</a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>


