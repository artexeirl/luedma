---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CatalogSection from '../../components/CatalogSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { products } from '../../data/snapshot';
---

<BaseLayout
  seo={{
    title: 'Tienda | Maquinarias Luedma',
    description: 'Tienda de productos con filtros por categorías y marcas.',
    canonicalPath: '/tienda/',
  }}
>
  <Header />

  <main id="contenido" class="section">
    <div class="container">
      <CatalogSection products={products} />
    </div>
  </main>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
