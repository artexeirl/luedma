---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CatalogSection from '../../../components/CatalogSection.astro';
import WhatsAppFloat from '../../../components/WhatsAppFloat.astro';
import { categories, products, getCategoryBySlug, getBrandBySlug } from '../../../data/snapshot';
import { shopCategoryPathFromSlugs } from '../../../utils/urls';

type PathParams = {
  slug?: string[];
};

export function getStaticPaths() {
  const categoryPaths = categories.map((category) => ({
    params: category.parentSlug
      ? { slug: [category.parentSlug, category.slug] }
      : { slug: [category.slug] },
  }));

  const brandCategoryPaths: Array<{params: PathParams}> = [];
  categories.forEach((category) => {
    const productsInCategory = products.filter((product) =>
      product.categorySlug === category.slug || getCategoryBySlug(product.categorySlug)?.parentSlug === category.slug,
    );
    const brandSlugs = Array.from(new Set(productsInCategory.map((product) => product.brandSlug)));

    brandSlugs.forEach((brandSlug) => {
      if (category.parentSlug) {
        brandCategoryPaths.push({ params: { slug: [category.parentSlug, category.slug, 'm', brandSlug] } });
      } else {
        brandCategoryPaths.push({ params: { slug: [category.slug, 'm', brandSlug] } });
      }
    });
  });

  return [...categoryPaths, ...brandCategoryPaths];
}

const slugParam = Astro.params.slug;
const parts = (Array.isArray(slugParam) ? slugParam : (slugParam || '').split('/')).filter(Boolean);

let categorySlug = '';
let brandSlug = '';

if (parts.length >= 2 && parts[0] === 'm') {
  brandSlug = parts[1];
} else if (parts.length >= 4 && parts[parts.length - 2] === 'm') {
  brandSlug = parts[parts.length - 1];
  categorySlug = parts[parts.length - 3];
} else if (parts.length >= 3 && parts[parts.length - 2] === 'm') {
  brandSlug = parts[parts.length - 1];
  categorySlug = parts[0];
} else if (parts.length >= 2) {
  categorySlug = parts[1];
} else if (parts.length === 1) {
  categorySlug = parts[0];
}

const selectedCategory = categorySlug ? getCategoryBySlug(categorySlug) : undefined;
const selectedBrand = brandSlug ? getBrandBySlug(brandSlug) : undefined;

if (!selectedCategory && !selectedBrand) {
  return Astro.redirect('/tienda/');
}

if (selectedBrand && !selectedCategory) {
  return Astro.redirect(`/tienda/m/${encodeURIComponent(selectedBrand.slug)}/`, 301);
}

if (brandSlug && !selectedBrand && selectedCategory) {
  return Astro.redirect(shopCategoryPathFromSlugs(selectedCategory.slug, selectedCategory.parentSlug));
}

const categoryCanonicalPath = selectedCategory
  ? shopCategoryPathFromSlugs(selectedCategory.slug, selectedCategory.parentSlug)
  : '/tienda/';
---

<BaseLayout
  seo={{
    title: `${selectedCategory?.name || 'Tienda'}${selectedBrand ? ` · ${selectedBrand.name}` : ''} | Maquinarias Luedma`,
    description: `Productos en ${selectedCategory?.name || 'Tienda'}${selectedBrand ? ` de la marca ${selectedBrand.name}` : ''}.`,
    canonicalPath: selectedBrand ? categoryCanonicalPath : Astro.url.pathname,
    noindex: Boolean(selectedBrand),
  }}
>
  <Header />

  <main id="contenido" class="section">
    <div class="container">
      <CatalogSection
        products={products}
        initialCategory={selectedCategory?.slug || ''}
        initialBrand={selectedBrand?.slug || ''}
      />
    </div>
  </main>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
