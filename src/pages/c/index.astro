---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CatalogSection from '../../components/CatalogSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { products } from '../../data/snapshot';
---

<BaseLayout
  seo={{
    title: 'Catálogo | Maquinarias Luedma',
    description: 'Catálogo de productos con filtros por islas TypeScript.',
    canonicalPath: '/c/',
  }}
>
  <Header />

  <main id="contenido" class="section">
    <div class="container">
      <CatalogSection products={products} title="Catálogo" subtitle="Vista completa de productos del snapshot local." />
    </div>
  </main>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
