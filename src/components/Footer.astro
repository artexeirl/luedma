---
import '../styles/components/footer.css';
import TrustStrip from './TrustStrip.astro';
import { categories, siteSettings } from '../data/snapshot';
import { SALES_EMAIL } from '../utils/contact';

const topCategories = categories
  .filter((category) => !category.parentSlug)
  .sort((a, b) => a.name.localeCompare(b.name, 'es', {sensitivity: 'base'}));
const footerCategories = topCategories.slice(0, 5);
const buildShopCategoryPath = (slug: string) => `/tienda/c/${encodeURIComponent(slug)}/`;
---

<TrustStrip />
<footer class="site-footer">
  <div class="container footer-shell">
    <div class="footer-main">
      <article class="footer-brand">
        <a class="footer-logo" href="/" aria-label="Ir al inicio">
          <img src={siteSettings.logo} alt={`Logo ${siteSettings.siteName}`} loading="lazy" />
        </a>
        <p>
          Especialistas en la venta de maquinaria industrial y herramientas profesionales. Ofrecemos equipos de alta calidad para la industria y hogar.
        </p>

        <ul class="footer-contact-list">
          <li>
            <img src="/icons/map-pin.svg" alt="" aria-hidden="true" />
            <span>{siteSettings.address}</span>
          </li>
          <li>
            <img src="/icons/phone-call.svg" alt="" aria-hidden="true" />
            <a href={`tel:+${siteSettings.whatsappNumber}`}>{siteSettings.phone}</a>
          </li>
          <li>
            <img src="/icons/mail.svg" alt="" aria-hidden="true" />
            <a href={`mailto:${SALES_EMAIL}`}>{SALES_EMAIL}</a>
          </li>
        </ul>
      </article>

      <article class="footer-column">
        <h3>Empresa</h3>
        <ul>
          <li><a href="/nosotros/">Sobre nosotros</a></li>
          <li><a href="/tienda/">Productos</a></li>
          <li><a href="/faq/">Preguntas Frecuentes</a></li>
          <li><a href="/metodos-de-pago/">Métodos de Pago</a></li>
          <li><a href="/contacto/">Contacto</a></li>
        </ul>
      </article>

      <article class="footer-column">
        <h3>Categorías</h3>
        <ul>
          {footerCategories.map((category) => (
            <li><a href={buildShopCategoryPath(category.slug)}>{category.name}</a></li>
          ))}
          {topCategories.length > footerCategories.length && (
            <li><a href="/tienda/">Ver más</a></li>
          )}
        </ul>
      </article>

      <article class="footer-column">
        <h3>Políticas</h3>
        <ul>
          <li><a href="/politica-de-devoluciones/">Política de Devoluciones</a></li>
          <li><a href="/politica-de-envios/">Política de Envíos</a></li>
          <li><a href="/politicas-de-privacidad/">Política de Privacidad</a></li>
          <li><a href="/terminos-y-condiciones/">Términos y Condiciones</a></li>
        </ul>
        <a class="footer-claims-link" href="/libro-de-reclamaciones/" aria-label="Ir al Libro de Reclamaciones">
          <img src="/images/libro-reclamaciones.webp" alt="Libro de Reclamaciones" loading="lazy" />
        </a>
      </article>
    </div>

    <div class="footer-bottom">
      <small>© 2026 Maquinarias Luedma. Diseñado y desarrollado por Artex.</small>

      <div class="footer-socials" aria-label="Redes sociales">
        {siteSettings.social.facebook && (
          <a href={siteSettings.social.facebook} target="_blank" rel="noreferrer" aria-label="Facebook">
            <img src="/icons/brand-facebook.svg" alt="" />
          </a>
        )}
        {siteSettings.social.instagram && (
          <a href={siteSettings.social.instagram} target="_blank" rel="noreferrer" aria-label="Instagram">
            <img src="/icons/brand-instagram.svg" alt="" />
          </a>
        )}
        <a href="https://www.tiktok.com/" target="_blank" rel="noreferrer" aria-label="TikTok">
          <img src="/icons/brand-tiktok.svg" alt="" />
        </a>
      </div>
    </div>
  </div>
</footer>
