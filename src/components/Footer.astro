---
import TrustStrip from './TrustStrip.astro';
import { brands, categories, siteSettings } from '../data/snapshot';

const topCategories = categories.filter((category) => !category.parentSlug).slice(0, 5);
const featuredBrands = brands.slice(0, 6);
const buildShopCategoryPath = (slug: string) => `/c/${encodeURIComponent(slug)}/`;
---

<TrustStrip />
<footer class="site-footer">
  <div class="container footer-shell">
    <div class="footer-main">
      <article class="footer-brand">
        <a class="footer-logo" href="/" aria-label="Ir al inicio">
          <img src={siteSettings.logo} alt={`Logo ${siteSettings.siteName}`} loading="lazy" />
        </a>
        <p>
          Herramientas y equipos para trabajo profesional, industria y hogar, con despacho rápido en Lima.
        </p>

        <ul class="footer-contact-list">
          <li>
            <img src="/icons/map-pin.svg" alt="" aria-hidden="true" />
            <span>Las Malvinas Jr. Huarochirí 560, Lima, Perú</span>
          </li>
          <li>
            <img src="/icons/phone-call.svg" alt="" aria-hidden="true" />
            <a href={`https://wa.me/${siteSettings.whatsappNumber}`} target="_blank" rel="noreferrer">{siteSettings.phone}</a>
          </li>
          <li>
            <img src="/icons/mail.svg" alt="" aria-hidden="true" />
            <a href="mailto:maquinariasluedma@gmail.com">maquinariasluedma@gmail.com</a>
          </li>
        </ul>
      </article>

      <article class="footer-column">
        <h3>Categorías</h3>
        <ul>
          {topCategories.map((category) => (
            <li><a href={buildShopCategoryPath(category.slug)}>{category.name}</a></li>
          ))}
        </ul>
      </article>

      <article class="footer-column">
        <h3>Marcas destacadas</h3>
        <ul>
          {featuredBrands.map((brand) => (
            <li><a href={brand.path}>{brand.name}</a></li>
          ))}
        </ul>
      </article>

      <article class="footer-column">
        <h3>Información</h3>
        <ul>
          <li><a href="/about-us/">Sobre nosotros</a></li>
          <li><a href="/contact/">Contacto</a></li>
          <li><a href="/libro-de-reclamaciones/">Libro de reclamaciones</a></li>
          <li><a href="/c/">Catálogo completo</a></li>
        </ul>
      </article>
    </div>

    <div class="footer-bottom">
      <small>{new Date().getFullYear()} {siteSettings.siteName}. Todos los derechos reservados.</small>

      <div class="footer-socials" aria-label="Redes sociales">
        {siteSettings.social.facebook && (
          <a href={siteSettings.social.facebook} target="_blank" rel="noreferrer" aria-label="Facebook">
            <img src="/icons/brand-facebook.svg" alt="" />
          </a>
        )}
        {siteSettings.social.instagram && (
          <a href={siteSettings.social.instagram} target="_blank" rel="noreferrer" aria-label="Instagram">
            <img src="/icons/brand-instagram.svg" alt="" />
          </a>
        )}
        <a href="https://www.tiktok.com/" target="_blank" rel="noreferrer" aria-label="TikTok">
          <img src="/icons/brand-tiktok.svg" alt="" />
        </a>
      </div>
    </div>
  </div>
</footer>


