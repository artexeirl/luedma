---
import '../styles/components/trust-strip.css';

const trustHighlights = [
  { icon: '/icons/package.svg', title: 'Envío express', description: 'Llevamos tus productos a tu casa' },
  { icon: '/icons/credit-card-shield.svg', title: 'Compras seguras', description: 'Tus compras son 100% protegidas' },
  { icon: '/icons/support.svg', title: 'Equipo especializado', description: 'Te ayudamos en lo que necesites' },
];
---

<section class="trust-strip" data-island="trust-strip" aria-label="Beneficios de compra">
  <div class="container">
    <div class="trust-strip__grid">
      {trustHighlights.map((item) => (
        <article class="trust-strip__item">
          <div class="trust-strip__content">
            <span class="trust-strip__icon" aria-hidden="true">
              <img src={item.icon} alt="" loading="lazy" />
            </span>
            <div class="trust-strip__text">
              <h2>{item.title}</h2>
              <p>{item.description}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
