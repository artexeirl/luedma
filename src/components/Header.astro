---
import '../styles/components/header.css';
import { brands, categories, getBrandBySlug, getCategoryBySlug, products, siteSettings } from '../data/snapshot';
import type { SearchIslandProps } from '../types/content';

const topCategories = categories.filter((category) => !category.parentSlug).slice(0, 5);
const buildShopCategoryPath = (slug: string) => `/tienda/c/${encodeURIComponent(slug)}/`;
const buildShopBrandFilterPath = (slug: string) => `/tienda/m/${encodeURIComponent(slug)}/`;
const topBrands = [
  { slug: 'bosch', name: 'Bosch', path: buildShopBrandFilterPath('bosch') },
  { slug: 'hilti', name: 'Hilti', path: buildShopBrandFilterPath('hilti') },
  { slug: 'karcher', name: 'Karcher', path: buildShopBrandFilterPath('karcher') },
  { slug: 'makita', name: 'Makita', path: buildShopBrandFilterPath('makita') },
  { slug: 'makute', name: 'Makute', path: buildShopBrandFilterPath('makute') },
  { slug: 'milwaukee', name: 'Milwaukee', path: buildShopBrandFilterPath('milwaukee') },
  { slug: 'ronix', name: 'Ronix', path: buildShopBrandFilterPath('ronix') },
];
const topCategoryPanels = topCategories
  .map((category) => ({
    ...category,
    shopPath: buildShopCategoryPath(category.slug),
    displayName: category.name,
    children: categories
      .filter((childCategory) => childCategory.parentSlug === category.slug)
      .map((childCategory) => ({
        ...childCategory,
        shopPath: `/tienda/c/${encodeURIComponent(category.slug)}/${encodeURIComponent(childCategory.slug)}/`,
        displayName: childCategory.name,
      }))
      .slice()
      .sort((a, b) => a.displayName.localeCompare(b.displayName, 'es', { sensitivity: 'base' })),
  }))
  .sort((a, b) => a.displayName.localeCompare(b.displayName, 'es', { sensitivity: 'base' }));
const brandBySlug = new Map(brands.map((brand) => [brand.slug, brand]));
const categoryChildrenByParent = new Map(
  categories
    .filter((category) => category.parentSlug)
    .reduce<Array<[string, string[]]>>((acc, category) => {
      const parentSlug = category.parentSlug as string;
      const existing = acc.find(([slug]) => slug === parentSlug);
      if (existing) {
        existing[1].push(category.slug);
      } else {
        acc.push([parentSlug, [category.slug]]);
      }
      return acc;
    }, []),
);

const topCategoryBrands = new Map(
  topCategoryPanels.map((category) => {
    const categoryScope = new Set([category.slug, ...(categoryChildrenByParent.get(category.slug) || [])]);
    const categoryBrands = Array.from(
      new Set(
        products
          .filter((product) => categoryScope.has(product.categorySlug))
          .map((product) => product.brandSlug),
      ),
    )
      .map((brandSlug) => brandBySlug.get(brandSlug))
      .filter((brand): brand is NonNullable<typeof brand> => Boolean(brand?.logo))
      .sort((a, b) => a.name.localeCompare(b.name, 'es', { sensitivity: 'base' }))
      .map((brand) => ({
        name: brand.name,
        slug: brand.slug,
        image: brand.logo as string,
      }));

    return [category.slug, categoryBrands];
  }),
);
const brandIconBySlug: Record<string, string> = {
  bosch: '/icons/tools/drill.svg',
  hilti: '/icons/tools/jackhammer.svg',
  karcher: '/icons/tools/spray-gun.svg',
  makita: '/icons/tools/saw.svg',
  makute: '/icons/tools/jigsaw.svg',
  milwaukee: '/icons/tools/saw-chainsaw.svg',
  ronix: '/icons/tools/circular-saw.svg',
};
const categoryIconBySlug: Record<string, string> = {
  'accesorios-de-herramientas': '/icons/tools/tools.svg',
  'equipos-de-taller': '/icons/tools/toolbox.svg',
  'herramientas-electricas': '/icons/tools/plug.svg',
  'herramientas-manuales': '/icons/tools/axe.svg',
  'seguridad-e-iluminacion': '/icons/tools/light-bulb-idea.svg',
};
const searchIndex = products.map((product) => ({
  slug: product.slug,
  name: product.name,
  path: product.path,
  brand: getBrandBySlug(product.brandSlug)?.name || product.brandSlug,
  category: getCategoryBySlug(product.categorySlug)?.name || product.categorySlug,
  sku: product.sku || '',
  image:
    product.images?.[0] && product.images[0].includes('cdn.sanity.io')
      ? `${product.images[0]}?w=112&h=112&fit=crop&auto=format`
      : product.images?.[0] || '/images/products/placeholder-product.svg',
  price: typeof product.price === 'number' ? product.price.toFixed(2) : '',
  stockText: (product.stock || 0) > 0 ? 'Stock disponible' : 'Sin stock',
}));

const searchProps: SearchIslandProps = {
  submitPath: '/search/',
  suggestionsLimit: 10,
};
---

<header class="site-header" data-island="mobile-menu">
  <div class="container site-header__top">
    <button
      data-mobile-menu-button
      class="header-mobile-menu-button header-mobile-menu-button--standalone"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
      aria-label="Abrir menú"
    >
      <span class="header-tool__icon" aria-hidden="true">
        <img src="/icons/menu-2.svg" alt="" />
      </span>
    </button>

    <a href="/" class="brand" aria-label="Ir al inicio">
      <img src={siteSettings.logo} width="260" height="78" alt="Logo Maquinarias Luedma" loading="eager" />
    </a>

    <div class="header-search-shell header-search-shell--desktop" data-island="search" data-island-props={JSON.stringify(searchProps)}>
      <form data-search-form class="header-search" action="/search/" method="get">
        <input data-search-input type="search" name="q" placeholder="¿Qué productos estás buscando?" autocomplete="off" />
        <button type="submit" aria-label="Buscar">
          <img src="/icons/search.svg" alt="" aria-hidden="true" />
        </button>
        <ul data-search-suggestions hidden></ul>
        <script type="application/json" data-search-index set:html={JSON.stringify(searchIndex)}></script>
      </form>
    </div>

    <div class="header-tools">
      <a class="header-location" href="/contacto/" aria-label="Actualizar ubicación de entrega">
        <span class="header-tool__icon" aria-hidden="true">
          <img src="/icons/map-pin.svg" alt="" />
        </span>
        <span class="header-location__text">
          <small>Ubícanos en</small>
          <strong>Jr. Huarochirí 560</strong>
        </span>
      </a>

      <button
        class="header-account header-coming-soon-trigger"
        type="button"
        aria-label="Iniciar sesión (próximamente)"
        data-coming-soon-message="Inicio de sesión aún en desarrollo. Pronto tendremos nuevas novedades"
      >
        <span class="header-tool__icon" aria-hidden="true">
          <img src="/icons/user.svg" alt="" />
        </span>
        <span>Iniciar sesión</span>
      </button>

      <button
        class="header-cart header-coming-soon-trigger"
        type="button"
        aria-label="Carrito de compras (próximamente)"
        data-coming-soon-message="Carrito compras aún en desarrollo. Pronto te traeremos nuevas novedades"
      >
        <span class="header-tool__icon" aria-hidden="true">
          <img src="/icons/garden-cart.svg" alt="" />
        </span>
        <span class="header-cart__badge">0</span>
      </button>

    </div>
  </div>

  <div class="site-header__bottom-wrap">
    <div class="container site-header__bottom">
      <a
        href="/tienda/"
        data-mobile-menu-button
        class="menu-trigger"
        aria-expanded="false"
        aria-controls="mobile-nav-panel mega-categories-panel"
      >
        <span class="header-tool__icon menu-trigger__icon" aria-hidden="true">
          <img src="/icons/category.svg" alt="" />
        </span>
        <span>Todas las categorías</span>
      </a>

      <nav class="header-nav" aria-label="Navegación principal">
        {topBrands.map((brand) => (
          <a href={brand.path} class="header-nav__brand">
            <span class="header-tool__icon header-nav__brand-icon" aria-hidden="true">
              <img
                class:list={{
                  'is-makita-flip': brand.slug === 'makita',
                  'is-milwaukee-scale': brand.slug === 'milwaukee',
                }}
                src={brandIconBySlug[brand.slug] || '/icons/tools/drill.svg'}
                alt=""
              />
            </span>
            <span>{brand.name}</span>
          </a>
        ))}
      </nav>

      <div class="header-shortcuts">
        <a href="/contacto/" class="header-shortcuts__item">
          <span class="header-tool__icon" aria-hidden="true">
            <img src="/icons/phone-call.svg" alt="" />
          </span>
          <span>+51 936 829 528</span>
        </a>
      </div>
    </div>

    <div id="mega-categories-panel" class="mega-menu" data-mega-menu-panel aria-hidden="true">
      <div class="container mega-menu__content">
        <aside class="mega-menu__categories" aria-label="categorías principales">
          {topCategoryPanels.map((category, index) => (
            <a
              href={category.shopPath}
              class:list={{ 'mega-menu__category-trigger': true, 'is-active': index === 0 }}
              data-mega-category-trigger
              data-category-slug={category.slug}
              aria-expanded={index === 0 ? 'true' : 'false'}
            >
              <span class="mega-menu__category-label">
                <span class="header-tool__icon mega-menu__category-icon" aria-hidden="true">
                  <img src={categoryIconBySlug[category.slug] || '/icons/tools/tools.svg'} alt="" />
                </span>
                <span>{category.displayName}</span>
              </span>
              <span aria-hidden="true">›</span>
            </a>
          ))}
        </aside>

        <div class="mega-menu__panels">
          {topCategoryPanels.map((category, index) => (
            <section
              class:list={{ 'mega-menu__panel': true, 'is-active': index === 0 }}
              data-mega-category-panel
              data-category-slug={category.slug}
            >
              <h3>{category.displayName}</h3>
              <ul class="mega-menu__subcategories">
                {category.children.map((childCategory) => (
                  <li>
                    <a href={childCategory.shopPath}>{childCategory.displayName}</a>
                  </li>
                ))}
              </ul>

              <div class="mega-menu__brands">
                <div class="mega-menu__brand-grid">
                  {(topCategoryBrands.get(category.slug) || []).map((brandLogo) => (
                    <a
                      href={`/tienda/c/${encodeURIComponent(category.slug)}/m/${encodeURIComponent(brandLogo.slug)}/`}
                      class="mega-menu__brand-item"
                      aria-label={`Ver productos ${brandLogo.name}`}
                    >
                      <img src={brandLogo.image} alt={brandLogo.name} loading="lazy" />
                    </a>
                  ))}
                </div>
              </div>
            </section>
          ))}
        </div>
      </div>
    </div>
  </div>
  <div class="mega-menu-backdrop" data-mega-menu-backdrop hidden></div>

  <aside id="mobile-nav-panel" data-mobile-menu-panel class="mobile-panel" hidden aria-hidden="true">
    <div class="mobile-panel__head">
      <div class="mobile-panel__search header-search-shell" data-island="search" data-island-props={JSON.stringify(searchProps)}>
        <form data-search-form class="header-search header-search--mobile" action="/search/" method="get">
          <input data-search-input type="search" name="q" placeholder="¿Qué productos estás buscando?" autocomplete="off" />
          <button type="submit" aria-label="Buscar">
            <img src="/icons/search.svg" alt="" aria-hidden="true" />
          </button>
          <ul data-search-suggestions hidden></ul>
          <script type="application/json" data-search-index set:html={JSON.stringify(searchIndex)}></script>
        </form>
      </div>
      <button data-mobile-menu-close type="button" aria-label="Cerrar menú">
        <img src="/icons/x.svg" alt="" aria-hidden="true" />
      </button>
    </div>

    <div class="mobile-tabs" role="tablist" aria-label="Navegación móvil">
      <button
        type="button"
        class="mobile-tabs__button is-active"
        data-mobile-tab-button
        data-mobile-tab-target="categories"
        role="tab"
        aria-selected="true"
      >
        Categorías
      </button>
      <button
        type="button"
        class="mobile-tabs__button"
        data-mobile-tab-button
        data-mobile-tab-target="brands"
        role="tab"
        aria-selected="false"
      >
        Marcas
      </button>
    </div>

    <div class="mobile-tabs__panels">
      <section class="mobile-tabs__panel is-active" data-mobile-tab-panel data-mobile-tab-panel-id="categories" role="tabpanel">
        <div class="mobile-panel__section">
          <div class="mobile-accordion">
            {topCategoryPanels.map((category, index) => (
              <article class:list={{ 'mobile-accordion__item': true, 'is-open': index === 0 }} data-mobile-accordion-item data-category-slug={category.slug}>
                <button
                  type="button"
                  class="mobile-accordion__trigger"
                  data-mobile-accordion-trigger
                  data-category-slug={category.slug}
                  aria-expanded={index === 0 ? 'true' : 'false'}
                >
                  <span class="mobile-accordion__trigger-label">
                    <span class="header-tool__icon mobile-accordion__category-icon" aria-hidden="true">
                      <img src={categoryIconBySlug[category.slug] || '/icons/tools/tools.svg'} alt="" />
                    </span>
                    <span>{category.displayName}</span>
                  </span>
                  <span class="mobile-accordion__chevron" aria-hidden="true">
                    <img src="/icons/chevron-down.svg" alt="" />
                  </span>
                </button>
                <div class="mobile-accordion__panel" data-mobile-accordion-panel data-category-slug={category.slug}>
                  <div class="mobile-accordion__panel-inner">
                    <a class="mobile-accordion__shop-link" href={category.shopPath} data-mobile-menu-close>
                      Ver todo en {category.displayName}
                    </a>
                    <ul>
                      {category.children.map((childCategory) => (
                        <li><a href={childCategory.shopPath} data-mobile-menu-close>{childCategory.displayName}</a></li>
                      ))}
                    </ul>
                  </div>
                </div>
              </article>
            ))}
          </div>
          <button class="mobile-panel__account header-coming-soon-trigger" type="button" data-coming-soon-message="Inicio de sesión aún en desarrollo. Pronto tendremos nuevas novedades" aria-label="Iniciar sesión (próximamente)">
            <span class="header-tool__icon" aria-hidden="true">
              <img src="/icons/user.svg" alt="" />
            </span>
            <span>Iniciar sesión</span>
          </button>
        </div>
      </section>

      <section class="mobile-tabs__panel" data-mobile-tab-panel data-mobile-tab-panel-id="brands" role="tabpanel">
        <div class="mobile-panel__section">
          <div class="mobile-panel__brands">
            {topBrands.map((brand) => (
              <a href={brand.path} class="mobile-panel__brand" data-mobile-menu-close>
                <span class="header-tool__icon mobile-panel__brand-icon" aria-hidden="true">
                  <img
                    class:list={{
                      'is-makita-flip': brand.slug === 'makita',
                      'is-milwaukee-scale': brand.slug === 'milwaukee',
                    }}
                    src={brandIconBySlug[brand.slug] || '/icons/tools/drill.svg'}
                    alt=""
                  />
                </span>
                <span>{brand.name}</span>
              </a>
            ))}
          </div>
          <a class="mobile-panel__view-all" href="/tienda/" data-mobile-menu-close>Ver todas</a>
          <button class="mobile-panel__account header-coming-soon-trigger" type="button" data-coming-soon-message="Inicio de sesión aún en desarrollo. Pronto tendremos nuevas novedades" aria-label="Iniciar sesión (próximamente)">
            <span class="header-tool__icon" aria-hidden="true">
              <img src="/icons/user.svg" alt="" />
            </span>
            <span>Iniciar sesión</span>
          </button>
        </div>
      </section>
    </div>
  </aside>
  <div class="header-coming-soon-backdrop" data-coming-soon-backdrop hidden></div>
  <div class="header-coming-soon-popover" data-coming-soon-popover hidden role="status" aria-live="polite"></div>
  <script is:inline>
    (() => {
      const root = document.currentScript?.closest('.site-header');
      if (!root) return;

      const triggers = Array.from(root.querySelectorAll('.header-coming-soon-trigger'));
      const popover = root.querySelector('[data-coming-soon-popover]');
      if (!triggers.length || !popover) return;

      let timer;
      let hideTransitionTimer;

      const hide = () => {
        if (timer) {
          clearTimeout(timer);
          timer = null;
        }
        if (hideTransitionTimer) {
          clearTimeout(hideTransitionTimer);
          hideTransitionTimer = null;
        }
        popover.classList.remove('is-visible');
        hideTransitionTimer = setTimeout(() => {
          popover.hidden = true;
          hideTransitionTimer = null;
        }, 220);
      };

      const show = (trigger) => {
        if (timer) {
          clearTimeout(timer);
          timer = null;
        }
        const rect = trigger.getBoundingClientRect();
        popover.textContent = trigger.getAttribute('data-coming-soon-message') || 'Función en desarrollo.';
        popover.style.top = `${rect.bottom + 10}px`;
        popover.style.left = `${rect.left + rect.width / 2}px`;
        if (hideTransitionTimer) {
          clearTimeout(hideTransitionTimer);
          hideTransitionTimer = null;
        }
        popover.classList.remove('is-visible');
        popover.hidden = false;
        requestAnimationFrame(() => popover.classList.add('is-visible'));
      };

      const scheduleHide = () => {
        timer = setTimeout(hide, 120);
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener('mouseenter', () => show(trigger));
        trigger.addEventListener('focus', () => show(trigger));
        trigger.addEventListener('mouseleave', scheduleHide);
        trigger.addEventListener('blur', scheduleHide);
        trigger.addEventListener('click', (event) => event.preventDefault());
      });

      window.addEventListener('scroll', hide, { passive: true });
      window.addEventListener('resize', hide);
    })();
  </script>
</header>







