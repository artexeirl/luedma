---
import '../styles/components/product-card.css';
import type { Product } from '../types/content';
import { getBrandBySlug, getCategoryBySlug } from '../data/snapshot';

type Props = {
  product: Product;
  hidden?: boolean;
  orderIndex?: number;
};

const { product, hidden = false, orderIndex = 0 } = Astro.props as Props;
const brand = getBrandBySlug(product.brandSlug);
const categoryTrail: string[] = [product.categorySlug];
let currentCategory = getCategoryBySlug(product.categorySlug);
while (currentCategory?.parentSlug) {
  categoryTrail.unshift(currentCategory.parentSlug);
  currentCategory = getCategoryBySlug(currentCategory.parentSlug);
}
const categoryRoot = categoryTrail[0] || product.categorySlug;
const cardImage =
  product.images[0] && product.images[0].includes('cdn.sanity.io')
    ? `${product.images[0]}?w=400&h=400&fit=crop&auto=format`
    : product.images[0];
---

<article
  class="product-card showcase-card"
  data-product-card
  data-name={product.name}
  data-sku={product.sku || ''}
  data-brand={product.brandSlug}
  data-category={product.categorySlug}
  data-category-root={categoryRoot}
  data-category-trail={categoryTrail.join(',')}
  data-order-index={String(orderIndex)}
  data-created-at={product.createdAt || ''}
  data-updated-at={product.updatedAt || ''}
  hidden={hidden}
>
  <a href={product.path} class="showcase-card__image-link product-card__image-link">
    <img
      class="product-card__image showcase-card__image"
      src={cardImage}
      alt={product.name}
      width="400"
      height="400"
      loading="lazy"
      decoding="async"
    />
  </a>

  <div class="showcase-card__meta">
    <p class="showcase-card__brand">{brand?.name ?? product.brandSlug}</p>
    {product.isNew && <span class="showcase-card__badge">NUEVO</span>}
  </div>

  <h3 class="showcase-card__name">
    <a href={product.path}>{product.name}</a>
  </h3>

  <div class="showcase-card__footer">
    <p class="showcase-card__sku">SKU: {product.sku || 'No especificado'}</p>
    <a class="btn btn-primary showcase-card__cta" href={product.path}>Ver detalles</a>
  </div>
</article>

