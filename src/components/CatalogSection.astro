---
import '../styles/components/catalog-section.css';
import ProductCard from './ProductCard.astro';
import type { FilterIslandProps, Product } from '../types/content';
import { brands, categories } from '../data/snapshot';

type Props = {
  products: Product[];
  title?: string;
  subtitle?: string;
  pageSize?: number;
  initialCategory?: string;
  initialBrand?: string;
  initialBrandLabel?: string;
  initialQuery?: string;
};

const {
  products,
  pageSize = 18,
  initialCategory = '',
  initialBrand = '',
  initialBrandLabel = '',
  initialQuery = '',
} = Astro.props as Props;

const filterProps: FilterIslandProps = { pageSize, initialCategory, initialBrand, initialQuery };
const brandOptions = brands
  .filter((brand) => products.some((item) => item.brandSlug === brand.slug))
  .sort((a, b) => a.name.localeCompare(b.name, 'es', { sensitivity: 'base' }));

const topCategories = categories
  .filter((category) => !category.parentSlug)
  .sort((a, b) => a.name.localeCompare(b.name, 'es', { sensitivity: 'base' }));
const childrenByParent = new Map(
  topCategories.map((parentCategory) => [
    parentCategory.slug,
    categories
      .filter((category) => category.parentSlug === parentCategory.slug)
      .sort((a, b) => a.name.localeCompare(b.name, 'es', { sensitivity: 'base' })),
  ]),
);

function getCategoryName(slug: string): string {
  return categories.find((c) => c.slug === slug)?.name || slug;
}

function buildCategoryBreadcrumb(slug: string): { label: string; slug: string }[] {
  const trail: { label: string; slug: string }[] = [];
  let current = categories.find((c) => c.slug === slug);
  while (current) {
    trail.unshift({ label: current.name, slug: current.slug });
    current = current.parentSlug ? categories.find((c) => c.slug === current!.parentSlug) : undefined;
  }
  return trail;
}

const initialBreadcrumb = initialCategory ? buildCategoryBreadcrumb(initialCategory) : [];
const initialCategoryName = initialCategory ? getCategoryName(initialCategory) : '';
const initialOpenCategorySlug = initialBreadcrumb[0]?.slug || topCategories[0]?.slug || '';

const normalizeText = (value: string): string =>
  value
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()
    .trim();

const matchesInitialCategory = (product: Product) => {
  if (!initialCategory) return true;
  const trail: string[] = [product.categorySlug];
  let currentCategory = categories.find((item) => item.slug === product.categorySlug);
  while (currentCategory?.parentSlug) {
    trail.unshift(currentCategory.parentSlug);
    currentCategory = categories.find((item) => item.slug === currentCategory?.parentSlug);
  }
  return trail.includes(initialCategory);
};

const matchesInitialBrand = (product: Product) => {
  if (!initialBrand) return true;
  return product.brandSlug === initialBrand;
};

const matchesInitialQuery = (product: Product) => {
  if (!initialQuery) return true;
  const clean = normalizeText(initialQuery);
  return normalizeText(`${product.name} ${product.brandSlug} ${product.categorySlug} ${product.sku || ''}`).includes(clean);
};

const productsSorted = [...products].sort((a, b) => a.name.localeCompare(b.name, 'es'));
const initialFilteredProducts = productsSorted.filter(
  (product) => matchesInitialCategory(product) && matchesInitialBrand(product) && matchesInitialQuery(product),
);
const initialTotalResults = initialFilteredProducts.length;
const initialTotalPages = Math.max(1, Math.ceil(initialTotalResults / pageSize));
const initialVisibleSlugs = new Set(initialFilteredProducts.slice(0, pageSize).map((product) => product.slug));
const initialSummary =
  initialTotalResults === 0
    ? 'No se encontraron productos con estos filtros.'
    : `${initialTotalResults} producto(s) encontrado(s)`;
---

<section class="catalog-section" data-island="catalog-controls" data-island-props={JSON.stringify(filterProps)}>
  <!-- Breadcrumb dinámico -->
  <nav class="catalog-breadcrumb" data-catalog-breadcrumb aria-label="Breadcrumb">
    <a href="/">INICIO</a>
    {initialBreadcrumb.length > 0 ? (
      initialBreadcrumb.map((item) => (
        <><span aria-hidden="true">/</span><a href={`/tienda/c/${item.slug}/`}>{item.label}</a></>
      ))
    ) : initialBrand && initialBrandLabel ? (
      <><span aria-hidden="true">/</span><span>{initialBrandLabel}</span></>
    ) : (
      <><span aria-hidden="true">/</span><span>TIENDA</span></>
    )}
  </nav>

  <!-- Título de categoría seleccionada -->
  <header class="catalog-section__head">
    <h2 class="catalog-section__title" data-catalog-title>
      {initialQuery ? `Resultados para: ${initialQuery}` : initialCategoryName ? `${initialCategoryName}` : 'TIENDA DE PRODUCTOS'}
    </h2>
  </header>

  <div class="catalog-shell">
    <div class="catalog-filters-drawer" data-filter-drawer>
      <button type="button" class="catalog-filters-drawer__backdrop" data-filter-close aria-label="Cerrar filtros"></button>
      <aside class="catalog-filters">
        <div class="catalog-filters__mobile-head">
          <h3>Filtros</h3>
          <button type="button" class="catalog-filters__mobile-close" data-filter-close aria-label="Cerrar filtros">
            <img src="/icons/x.svg" alt="" aria-hidden="true" />
          </button>
        </div>

        <div class="catalog-filters__group">
          <div class="catalog-filters__group-title">Categorías</div>
          <div class="catalog-accordion" data-filter-category-accordion>
            {topCategories.map((parentCategory, index) => (
              <article
                class:list={{
                  'catalog-accordion__item': true,
                  'is-open': parentCategory.slug === initialOpenCategorySlug || (!initialOpenCategorySlug && index === 0),
                }}
                data-filter-category-item
              >
                <div class="catalog-accordion__trigger">
                  <button
                    type="button"
                    class="catalog-accordion__text-btn"
                    data-filter-category-option
                    data-value={parentCategory.slug}
                    data-parent={parentCategory.slug}
                    data-href={`/tienda/c/${encodeURIComponent(parentCategory.slug)}/`}
                  >
                    <span>{parentCategory.name}</span>
                  </button>
                  <button
                    type="button"
                    class="catalog-accordion__icon-btn"
                    data-filter-category-trigger
                    aria-expanded={parentCategory.slug === initialOpenCategorySlug || (!initialOpenCategorySlug && index === 0) ? 'true' : 'false'}
                    aria-label={`Expandir ${parentCategory.name}`}
                  >
                    <span class="catalog-accordion__chevron" aria-hidden="true">
                      <img src="/icons/chevron-down.svg" alt="" />
                    </span>
                  </button>
                </div>
                <div class="catalog-accordion__panel">
                  <div class="catalog-accordion__panel-inner">
                    {childrenByParent.get(parentCategory.slug)?.map((childCategory) => (
                      <button
                        type="button"
                        class="catalog-option catalog-option--child"
                        data-filter-category-option
                        data-value={childCategory.slug}
                        data-parent={parentCategory.slug}
                        data-href={`/tienda/c/${encodeURIComponent(parentCategory.slug)}/${encodeURIComponent(childCategory.slug)}/`}
                      >
                        {childCategory.name}
                      </button>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="catalog-filters__group">
          <div class="catalog-filters__group-title">Marcas</div>
          <div class="catalog-brands" data-filter-brand-list>
            {brandOptions.map((brand) => (
              <button type="button" class="catalog-brand-option" data-filter-brand-option data-value={brand.slug}>
                <span class="catalog-brand-option__box" aria-hidden="true"></span>
                <span>{brand.name}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="catalog-filters__actions">
          <button type="button" class="btn btn-primary" data-filter-reset>Limpiar filtros</button>
        </div>

        <select data-filter-category hidden aria-hidden="true" tabindex="-1">
          <option value="">Todas las categorías</option>
          {topCategories.map((parentCategory) => (
            <>
              <option value={parentCategory.slug}>{parentCategory.name}</option>
              {childrenByParent.get(parentCategory.slug)?.map((childCategory) => (
                <option value={childCategory.slug}>{childCategory.name}</option>
              ))}
            </>
          ))}
        </select>

        <select data-filter-brand hidden aria-hidden="true" tabindex="-1">
          <option value="">Todas las marcas</option>
          {brandOptions.map((brand) => (
            <option value={brand.slug}>{brand.name}</option>
          ))}
        </select>
      </aside>
    </div>

    <div class="catalog-results">
    <div class="catalog-results__bar">
      <div class="catalog-results__bar-left">
        <button type="button" class="catalog-mobile-filters-trigger" data-filter-open>
          <img src="/icons/filter.svg" alt="" aria-hidden="true" />
          <span>Filtros</span>
        </button>
        <button type="button" class="catalog-reset-inline catalog-reset-inline--mobile" data-filter-active-reset hidden>
          <img src="/icons/filter.svg" alt="" aria-hidden="true" />
          <span>Limpiar filtros</span>
        </button>
      </div>
      <div class="catalog-results__info">
        <p class:list={{ 'catalog-summary': true, 'is-empty': initialTotalResults === 0 }} data-filter-summary>{initialSummary}</p>
        <button type="button" class="catalog-reset-inline catalog-reset-inline--desktop" data-filter-active-reset hidden>
          <img src="/icons/filter.svg" alt="" aria-hidden="true" />
          <span>Limpiar filtros</span>
        </button>
      </div>
      <label class="catalog-results__sort">
          <span>Ordenar por</span>
          <select data-filter-sort>
            <option value="">Relevancia</option>
            <option value="name-asc">Nombre A-Z</option>
            <option value="name-desc">Nombre Z-A</option>
            <option value="date-desc">Más nuevo</option>
            <option value="date-asc">Más antiguo</option>
          </select>
        </label>
      </div>

      <div class="product-grid" data-catalog-grid>
        {productsSorted.map((product, index) => (
          <ProductCard product={product} orderIndex={index} hidden={!initialVisibleSlugs.has(product.slug)} />
        ))}
      </div>

      <nav class="catalog-pagination" data-pagination hidden={initialTotalResults <= pageSize} aria-label="Paginación de productos">
        <button type="button" class="btn btn-outline catalog-pagination__nav-btn" data-page-prev disabled>
          <img src="/icons/chevron-left.svg" alt="" aria-hidden="true" />
        </button>
        <div class="catalog-pagination__numbers" data-page-numbers>
          <button type="button" aria-current="page">1</button>
          {initialTotalPages > 1 && <button type="button">2</button>}
        </div>
        <button type="button" class="btn btn-outline catalog-pagination__nav-btn" data-page-next disabled={initialTotalPages <= 1}>
          <img src="/icons/chevron-right.svg" alt="" aria-hidden="true" />
        </button>
      </nav>
    </div>
  </div>
</section>
