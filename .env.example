# ============================================================
# Astro Frontend (variables públicas, expuestas al cliente)
# ============================================================
PUBLIC_SANITY_PROJECT_ID=1c4assmu
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2025-01-01

# ============================================================
# Sanity Studio (CLI y deploy)
# Usa las mismas que el frontend para apuntar al mismo proyecto
# ============================================================
SANITY_STUDIO_PROJECT_ID=1c4assmu
SANITY_STUDIO_DATASET=production

# ============================================================
# Token de lectura (opcional, solo para previews / dataset privado)
# ============================================================
SANITY_READ_TOKEN=
SANITY_WRITE_TOKEN=

# ============================================================
# Correo para el Libro de Reclamaciones
# Usa SMTP real para enviar al cliente y a la empresa
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
CLAIMS_FROM_EMAIL=
CLAIMS_TO_EMAIL=maquinariasluedma@gmail.com
